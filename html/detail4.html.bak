<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>景德镇制瓷｜非遗详情-薪火拾遗</title>
<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:"Microsoft YaHei",SimSun,serif;
}
html{
  scroll-behavior: smooth;
}

/* 全局背景（和overview统一） */
body{
  background-color: #6d0f1d;
  background-image: linear-gradient(rgba(180,40,60,0.22) 1px,transparent 1px),
                    linear-gradient(90deg,rgba(180,40,60,0.22) 1px,transparent 1px);
  background-size:30px 30px;
}

/* 导航栏置顶【最顶部】和overview样式颜色统一 */
.nav {
  width:100%;
  background: #a91628;
  padding: 18px 0;
  display: flex;
  justify-content: center;
  align-items: center;
  gap:26px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.2);
  position: sticky;
  top:0;
  z-index:999;
}
.nav a {
  color:#fff;
  text-decoration:none;
  font-size:16px;
  transition: all 0.3s;
}
.nav a:hover{
  color:#ffd358;
}

/* ========== 面包屑导航样式 ========== */
.breadcrumb {
  max-width: 1080px;
  margin: 20px auto;
  padding: 0 20px;
  color: #fff;
  font-size: 15px;
}
.breadcrumb ul {
  list-style: none;
  display: flex;
  gap: 8px;
  align-items: center;
}
.breadcrumb li a {
  color: #ffd358;
  text-decoration: none;
}
.breadcrumb li a:hover {
  text-decoration: underline;
}
.breadcrumb li:not(:last-child)::after {
  content: ">";
  color: #ccc;
  margin-left: 8px;
}
.breadcrumb li:last-child {
  color: #ffffff;
  font-weight: bold;
}

/* 导航下方全屏banner图 */
.top-banner{
  width:100%;
  height:450px;
  background:url("../images1/2.4.png") center no-repeat;
  background-size: cover;
}

/* 一键返回顶部按钮 */
#backTop{
  position:fixed;
  right:30px;
  bottom:30px;
  width:45px;
  height:45px;
  background:#ffd358;
  color:#a91628;
  text-align:center;
  line-height:45px;
  border-radius:50%;
  cursor:pointer;
  font-size:20px;
  font-weight:bold;
  box-shadow:0 3px 8px rgba(0,0,0,0.2);
  transition:0.3s;
  z-index:999;
  display:none;
}
#backTop:hover{
  background:#ffc107;
  transform:scale(1.1);
}

/* banner下方独立标题区域 */
.banner-title-box{
  padding:35px 20px;
  text-align:center;
}
.banner-title-box h1{
  font-size:42px;
  color:#ffd358;
  margin-bottom:12px;
}
.banner-title-box p{
  font-size:18px;
  color:#ffffff;
  opacity:0.9;
}

/* 容器居中 */
.container{
  width:100%;
  max-width: 1080px;
  margin: 0 auto;
  padding: 0 20px 50px;
}

/* 深红色悬浮开窗卡片 */
.window-card{
  background: #821427;
  padding: 36px;
  border-radius: 16px;
  box-shadow: 0 8px 25px rgba(0,0,0,0.3);
  margin-bottom: 50px;
  transition: 0.35s ease;
  text-align: center;
}
.window-card:hover{
  transform: translateY(-6px);
  box-shadow: 0 14px 35px rgba(0,0,0,0.4);
}

/* 默认内部样式 */
.window-hole{
  padding: 30px;
  border-radius: 12px;
  border: 1px solid rgba(255,211,88,0.2);
}
.window-hole h2{
  color: #ffd358;
  font-size: 24px;
  margin-bottom: 20px;
}
.window-hole p{
  color: #fff;
  line-height: 2;
  font-size: 15px;
  margin-bottom: 12px;
  text-align: center;
  text-indent: 0;
}

/* 背景图卡片 */
.last-card {
  position: relative;
}
.last-card .window-hole{
  background: url('../images1/6.2.png') center center fixed;
  background-size: cover;
}

/* 教学视频区域 */
.video-block{
  background: rgba(130,20,39,0.9);
  padding: 40px;
  border-radius: 16px;
  margin-bottom: 50px;
  text-align: center;
}
.video-block h2{
  color: #ffd358;
  text-align: center;
  margin-bottom: 30px;
  font-size: 24px;
}
.video-row{
  display: flex;
  flex-wrap: wrap;
  gap: 30px;
  align-items: center;
}
.video-box{
  flex: 1;
  min-width: 450px;
}
.video-box video{
  width:100%;
  border-radius:10px;
  border:2px solid #ffd358;
}
.video-desc{
  flex: 1;
  min-width: 300px;
  color: #fff;
  text-align: center;
}
.video-desc h3{
  color: #ffd358;
  margin-bottom:15px;
}
.video-desc p{
  line-height:1.9;
  margin-bottom:10px;
}

/* 作品叠放展示 */
.work-block{
  margin-bottom:60px;
  text-align:center;
}
.work-block h2{
  color: #ffd358;
  text-align:center;
  margin-bottom:40px;
  font-size:24px;
}
.work-wrap{
  display:flex;
  justify-content:center;
  position:relative;
  flex-wrap:wrap;
  min-height:280px;
}
.work-item{
  width:200px;
  height:240px;
  margin-left:-40px;
  position:relative;
  z-index:1;
  transition:0.4s ease;
}
.work-item:first-child{
  margin-left:0;
}
.work-item img{
  width:100%;
  height:100%;
  object-fit:cover;
  border-radius:10px;
  border:2px solid #ffd358;
  box-shadow:0 5px 15px rgba(0,0,0,0.3);
}
.work-item:hover{
  transform:translateY(-20px) scale(1.05);
  z-index:99;
}

/* 返回按钮 */
.back-box{
  text-align:center;
  margin-bottom:40px;
}
.btn{
  padding:12px 30px;
  background:#ffd358;
  color:#a91628;
  border:none;
  border-radius:8px;
  font-size:16px;
  font-weight:bold;
  cursor:pointer;
  transition:0.3s;
}
.btn:hover{
  background:#ffc107;
}

/* 页脚 */
.footer{
  background:#590c1a;
  color:#ddd;
  text-align:center;
  padding:30px 0;
  border-top:1px solid rgba(255,211,88,0.1);
}
</style>
</head>

<body>
<!-- 导航栏 -->
<div class="nav">
  <a href="../index.html">首页</a>
  <a href="over.html">非遗总览</a>
  <a href="game.html">闯关抽卡</a>
  <a href="story.html">传承纪实</a>
  <a href="message.html">守护留言</a>
</div>

<!-- 全屏banner -->
<div class="top-banner"></div>

<!-- ========== 面包屑放在这里 ========== -->
<div class="breadcrumb">
  <ul>
    <li><a href="../index.html">首页</a></li>
    <li><a href="over.html">非遗总览</a></li>
    <li>景德镇制瓷</li>
  </ul>
</div>

<!-- 标题 -->
<div class="banner-title-box">
  <h1>🏺 景德镇制瓷 · 世界级非遗</h1>
  <p>千年瓷都匠心 · 火与土的千年艺术</p>
</div>

<!-- 正文内容 -->
<div class="container">
  <!-- 溯源 -->
  <div class="window-card">
    <div class="window-hole">
      <h2>📜 非遗溯源 · 千年瓷都传奇</h2>
      <p>景德镇制瓷始于汉代，兴于唐宋，盛于明清，历经千年薪火不息，被誉为“世界瓷都”。</p>
      <p>景德镇手工制瓷技艺完整保留72道传统工序，青花瓷、粉彩瓷、玲珑瓷、颜色釉并称四大名瓷，2006年入选国家级非遗。</p>
    </div>
  </div>

  <!-- 制作工序 -->
  <div class="window-card">
    <div class="window-hole">
      <h2>⚙️ 传统制瓷72道工序</h2>
      <p>【采石制泥】开采高岭土，历经淘洗、揉泥、陈腐，制成细腻瓷泥。</p>
      <p>【拉坯利坯】手工旋转成型，修坯定型，器型规整流畅。</p>
      <p>【施釉绘画】蘸釉、荡釉、青花绘画，赋予瓷器灵魂与色彩。</p>
      <p>【入窑烧制】高温烧制数小时，火中取宝，终成传世瓷器。</p>
    </div>
  </div>

  <!-- 背景卡片 -->
  <div class="window-card last-card">
    <div class="window-hole">
      <p>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</p>
      <p>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</p>
      <p>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</p>
      <p>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</p>
      <p>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</p>
      <p>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</p>
    </div>
  </div>

  <!-- 传承创新 -->
  <div class="window-card">
    <div class="window-hole">
      <h2>🎨 非遗传承与当代创新</h2>
      <p>景德镇从传统官窑走向文创、国潮、日用瓷、艺术瓷全产业链，吸引全球匠人前来追梦。</p>
      <p>年轻陶艺家将现代设计与古法技艺结合，让千年瓷器走进现代生活，走向世界舞台。</p>
      <p>一捧泥土，一把窑火，一双巧手，铸就中国陶瓷的千年辉煌。</p>
    </div>
  </div>

  <!-- 教学视频 -->
  <div class="video-block">
    <h2>🎬 制瓷技艺教学视频</h2>
    <div class="video-row">
      <div class="video-box">
        <video src="../images2/zhici.mp4" controls></video>
      </div>
      <div class="video-desc">
        <h3>制瓷零基础体验</h3>
        <p>景德镇非遗匠人亲自演示，从揉泥、拉坯到上釉、烧制全过程展示。</p>
        <p>直观感受火与土的艺术魅力，了解一件精美瓷器诞生的全部秘密。</p>
      </div>
    </div>
  </div>

  <!-- 作品欣赏 -->
  <div class="work-block">
    <h2>🖼 景德镇经典瓷器欣赏</h2>
    <div class="work-wrap">
      <div class="work-item"><img src="../images2/ci1.png"></div>
      <div class="work-item"><img src="../images2/ci2.png"></div>
      <div class="work-item"><img src="../images2/ci3.png"></div>
      <div class="work-item"><img src="../images2/ci4.png"></div>
      <div class="work-item"><img src="../images2/4.2.png"></div>
    </div>
  </div>

  <div class="back-box">
    <button class="btn" onclick="location.href='over.html'">← 返回非遗总览</button>
  </div>
</div>

<!-- 返回顶部 -->
<div id="backTop" onclick="backTop()">↑</div>

<div class="footer">
  <p>薪火拾遗 · 中国非遗文化博览 | 前端课程设计</p>
</div>

<script>
function backTop(){
  window.scrollTo({top:0,behavior:"smooth"});
}
window.onscroll = function(){
  let btn = document.getElementById("backTop");
  btn.style.display = window.scrollY > 300 ? "block" : "none";
}
</script>

</body>
</html>